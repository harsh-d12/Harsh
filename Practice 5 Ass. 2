prices = tuple(map(int, input("Enter prices of sold items separated by space: ").split()))

print("Prices:", prices)

print("a) Total number of items sold:", len(prices))

print("b) Price of cheapest item sold:", min(prices))

print("c) Price of costliest item sold:", max(prices))

sorted_prices = sorted(prices)
print("d) Price list in ascending order:", sorted_prices)

costliest = max(prices)
count = prices.count(costliest)
print("e) Number of costliest items sold on the day:", count)
